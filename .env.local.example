# ============================================================
# Bloom Avenue Le Spa — Environment Variables
# Copy these into your .env.local file
# Also add them in Vercel: Settings → Environment Variables
# ============================================================

# Supabase — get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin login password (choose any strong password)
ADMIN_PASSWORD=change-me-to-something-strong

# Random secret for signing admin session tokens (min 32 chars)
ADMIN_SECRET=change-me-to-a-long-random-string-min-32-chars

# WhatsApp notification to owner on every new booking (free via CallMeBot)
# Setup: see instructions below — takes 30 seconds on the owner's phone
OWNER_PHONE=+23054785001
CALLMEBOT_API_KEY=your-callmebot-api-key-here
